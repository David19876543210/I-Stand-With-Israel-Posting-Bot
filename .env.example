# ── Required ──────────────────────────────────────────────────

# Telegram Bot Token (from BotFather) — used for sending to target channels
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklmNOPqrstUVwxyz

# OpenRouter API key for translations + AI ad detection
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PostgreSQL database URL (Railway, Neon, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host:5432/telegram_forwarder

# Vercel deployment URL (used for webhook setup)
NEXTAUTH_URL=https://your-app.vercel.app

# ── For reading source channels (Telethon user client) ───────
# Required if you're NOT an admin in source channels.
# Get these from https://my.telegram.org/apps
API_ID=21234426
API_HASH=your_api_hash_here
PHONE_NUMBER=+972501234567
SESSION_STRING=your_session_string_here
SOURCE_CHANNEL_IDS=1406113886,1143765178

# ── Poller → Vercel ingest auth ───────────────────────────────
INGEST_URL=https://your-app.vercel.app
INGEST_SECRET=choose-a-random-secret

# ── Optional ──────────────────────────────────────────────────

# OpenRouter model override (default: openai/gpt-oss-120b:free)
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# Telegram webhook secret (optional, for extra security)
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# Cron job protection (optional, but recommended for production)
CRON_SECRET=your-cron-secret
